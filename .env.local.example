# CQ Signal local environment.
# Fastest setup: run `vercel env pull .env.local` after linking the project.
# That brings down DATABASE_URL, BLOB_READ_WRITE_TOKEN, VERCEL_OIDC_TOKEN,
# plus anything added in the Vercel dashboard.

# AI provider (one of these; Gateway preferred for production)
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=

# Database (Neon Postgres, provisioned via Vercel Marketplace)
DATABASE_URL=

# Blob storage (Vercel Blob, for logos and generated reports)
BLOB_READ_WRITE_TOKEN=

# Credential encryption key for OAuth tokens and API keys at rest.
# Generate with: openssl rand -base64 32
# Add the same value to the Vercel project env so deploys can decrypt.
CQ_SIGNAL_SECRET=

# Google OAuth (GA4 integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta Developer App (Meta Ads + Facebook Pages + Instagram)
META_APP_ID=
META_APP_SECRET=

# Clerk auth (coming with user auth wiring)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
